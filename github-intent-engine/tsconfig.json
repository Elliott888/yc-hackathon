{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": [
    "track-a-harvester/src/**/*.ts",
    "track-a-harvester/test/**/*.ts",
    "track-b-intelligence/src/**/*.ts",
    "track-b-intelligence/test/**/*.ts"
  ]
}
