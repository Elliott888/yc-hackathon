# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!**/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# nested hackathon workspaces
**/node_modules/
**/.playwright-cli/
**/.next/
**/dist/
**/build/
**/coverage/

# generated harvest, embedding, and model outputs
github-intent-engine/data/*
!github-intent-engine/data/eval/
github-intent-engine/data/eval/*
!github-intent-engine/data/eval/.gitkeep
!github-intent-engine/data/processed/
github-intent-engine/data/processed/*
!github-intent-engine/data/processed/.gitkeep

neural-github-intent/data/*
neural-github-intent/data-live-smoke/*
neural-github-intent/embeddings/*
!neural-github-intent/embeddings/.gitkeep
neural-github-intent/evals/*
!neural-github-intent/evals/.gitkeep
neural-github-intent/model-experiments/*
!neural-github-intent/model-experiments/.gitkeep

github-user-deepener/data/*
